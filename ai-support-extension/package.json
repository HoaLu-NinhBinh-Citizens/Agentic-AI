{
  "name": "ai-support",
  "displayName": "AI Support - Embedded Engineering Assistant",
  "version": "0.1.0",
  "publisher": "carv-dev",
  "description": "AI-powered embedded engineering assistant for CARV firmware development with local LLM integration",
  "categories": ["Other", "Programming Languages", "Machine Learning"],
  "keywords": ["ai", "embedded", "firmware", "stm32", "ollama", "carv"],
  "license": "MIT",
  "homepage": "https://github.com/carv-dev/ai-support-extension",
  "repository": {
    "type": "git",
    "url": "https://github.com/carv-dev/ai-support-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:ai-support.analyzeCode",
    "onCommand:ai-support.generateDriver",
    "onCommand:ai-support.analyzeHardware",
    "onCommand:ai-support.explainRegister",
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./extension/dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-support.analyzeCode",
        "title": "AI Support: Analyze Selected Code",
        "category": "AI Support",
        "enablement": "editorHasSelection"
      },
      {
        "command": "ai-support.generateDriver",
        "title": "AI Support: Generate Driver",
        "category": "AI Support"
      },
      {
        "command": "ai-support.analyzeHardware",
        "title": "AI Support: Analyze Hardware Dependencies",
        "category": "AI Support"
      },
      {
        "command": "ai-support.explainRegister",
        "title": "AI Support: Explain Register/Peripheral",
        "category": "AI Support"
      },
      {
        "command": "ai-support.validateConfig",
        "title": "AI Support: Validate MCU Configuration",
        "category": "AI Support"
      },
      {
        "command": "ai-support.searchDocs",
        "title": "AI Support: Search Documentation",
        "category": "AI Support"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ai-support.analyzeCode",
          "when": "editorHasSelection",
          "group": "ai-support@1"
        },
        {
          "command": "ai-support.explainRegister",
          "when": "editorHasSelection",
          "group": "ai-support@2"
        }
      ],
      "commandPalette": [
        {
          "command": "ai-support.generateDriver",
          "when": "false"
        },
        {
          "command": "ai-support.analyzeHardware",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "AI Support",
      "properties": {
        "ai-support.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API base URL"
        },
        "ai-support.model": {
          "type": "string",
          "default": "llama3.1:latest",
          "description": "LLM model to use"
        },
        "ai-support.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum tokens to generate"
        },
        "ai-support.projectRoot": {
          "type": "string",
          "default": "${workspaceFolder}",
          "description": "Project root directory"
        },
        "ai-support.enableContext": {
          "type": "boolean",
          "default": true,
          "description": "Include project context in requests"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-support-sidebar",
          "title": "AI Support"
        }
      ]
    },
    "views": {
      "ai-support-sidebar": [
        {
          "id": "ai-support.explorer",
          "name": "Context Explorer",
          "icon": "$(circuit-board)"
        },
        {
          "id": "ai-support.hardware",
          "name": "Hardware View",
          "icon": "$(server)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.21.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
